<%
  # Locals: suggested_quantity, suggested_portion, suggested_potency
%>
<div id="calculator-widget">
  <div class="calculator-item">
    <p class="subtitle"><%= t('calculator.step1_weed_quantity') %></p>
    <input id="grams-slider"
      type="text"
      data-slider-id="green-bar"
      data-slider-min="0.1"
      data-slider-max="28"
      data-slider-step="0.1"
      data-slider-value="<%= suggested_quantity %>"
      data-slider-tooltip="hide"/>

      <div class="text-right">
        <p>
          <a href="#" id="decrease-quantity">
            <i class="fa fa-minus-circle fa-lg yellow" aria-hidden="true"></i>
          </a>
          <input id="grams-input" type="number" step="any" class="calculator-input" onchange="updateQuantity(this.value)"> </input><span id="grams-quantity-label"></span>
          <a href="#" id="increase-quantity">
            <i class="fa fa-plus-circle fa-lg green" aria-hidden="true"></i>
          </a>
        </p>
      </div>
  </div>

  <div class="calculator-item">
    <p class="subtitle"><%= t('calculator.step1_weed_intensity') %></p>
    <span class="bottomtip"><%= t('calculator.step1_weed_intensity_average') %></span>
    <a class="label-calculator" data-toggle="modal" href="#" data-target="#myModal">
      <span class="badge badge-success">
        <%= t('calculator.step1_potency_dont_know') %>
      </span>
    </a>
    <input id="strength-slider"
          type="text"
          data-slider-id="green-bar"
          data-slider-min="1"
          data-slider-max="95"
          data-slider-step="1"
          data-slider-value="<%= suggested_potency %>"
          data-slider-tooltip="hide"/>

    <%= render "recipes/modal_potency" %>
    <p class="text-right">
      <a href="#" id="decrease-strength">
        <i class="fa fa-minus-circle fa-lg yellow" aria-hidden="true"></i>
      </a>
      THC: <input id="strength-input" type="number" step="any" class="calculator-input" onchange="updateStrength(this.value)"></input> %
      <a href="#" id="increase-strength">
        <i class="fa fa-plus-circle fa-lg green" aria-hidden="true"></i>
      </a>
    </p>
  </div>

  <div class="calculator-item">
    <p class="subtitle"><%= t('calculator.step1_weed_portions') %></p>
    <input id="portion-slider"
        type="text"
        data-slider-id="green-bar"
        data-slider-min="0.5"
        data-slider-max="200"
        data-slider-step="1"
        data-slider-value="<%= suggested_portion %>"
        data-slider-tooltip="hide"/>

    <div class="text-right">
      <p>
        <a href="#" id="decrease-servings">
          <i class="fa fa-minus-circle fa-lg yellow" aria-hidden="true"></i>
        </a>
        <input id="portion-input" type="number" step="any" class="calculator-input" onchange="updatePortion(this.value)"></input> <span id="portion-label"></span>
        <a href="#" id="increase-servings">
          <i class="fa fa-plus-circle fa-lg green" aria-hidden="true"></i>
        </a>
      </p>
    </div>
  </div>
</div>