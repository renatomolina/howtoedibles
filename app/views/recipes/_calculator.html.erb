<div class="col-sm-12 padding-container ui-item">
  <h4 class="col-sm-12">
    <i class="fa fa-calculator fa-lg" aria-hidden="true"></i> <%= t :step1_title %> <%= @recipe.name.capitalize %>
  </h4>
  <div class="row top-buffer meter-container">
    <div class="row">
      <div class="col-sm-12">
        <h5 class="pull-center"><%= t :step1_weed_quantity %></h5>
      </div>
    </div>

    <div class="row">
      <div class="col-sm-12">
        <input id="grams"
          type="text"
          data-slider-id="slider"
          data-slider-min="1"
          data-slider-max="28"
          data-slider-step="0.1"
          data-slider-value="<%= @recipe.suggested_weed %>"
          data-slider-tooltip="hide"/>
      </div>
      <div class="col-sm-12">
        <h5 class="pull-right" id="grams-quantity"></h5>
      </div>
    </div>
  </div>

  <div class="row top-buffer meter-container">
    <div class="row">
      <div class="col-sm-12">
        <h5 class="pull-center"><%= t :step1_weed_intensity %>
        </h5>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12">
        <input id="strength"
          type="text"
          data-slider-id="slider"
          data-slider-min="1"
          data-slider-max="95"
          data-slider-step="1"
          data-slider-value="10"
          data-slider-tooltip="hide"/>
      </div>
      <div class="col-sm-12">
        <a class="label label-warning pull-left label-calculator" data-toggle="modal" data-target="#myModal"><%= t :step1_potency_dont_know %></a>
        <h5 class="pull-right" id="strength-quantity"></h5>
      </div>
      <%= render "modal_potency" %>
    </div>
  </div>

  <div class="row top-buffer meter-container">
    <div class="row">
      <div class="col-sm-12">
        <h5 class="pull-center"><%= t :step1_weed_portions %></h5>
      </div>
    </div>
    <div class="row">
      <div class="col-sm-12">
        <input id="number-of-servings"
          type="text"
          data-slider-id="slider"
          data-slider-min="1"
          data-slider-max="80"
          data-slider-step="1"
          data-slider-value="<%= @recipe.suggested_portion %>"
          data-slider-tooltip="hide"/>
      </div>
      <div class="col-sm-12">
        <h5 class="pull-right" id="servings-quantity"></h5>
      </div>
    </div>
  </div>
</div>
