<div class="mtb col-sm-12">
  <h4 class="container">
    <i class="fa fa-arrow-circle-up fa-lg green" aria-hidden="true"></i>
    Popular recipes
  </h4>
  <hr>
  <% @recipes.each do |recipe| %>
    <%= link_to recipe_path(recipe.category.slug, recipe.slug) do %>
      <div class="col-sm-3 col-md-3">
        <div class="card">
            <%= image_tag(recipe.photo.url,  class: 'card-img-top') %>
            <div class="card-block text-right">
                <h3 class="card-title"><%= recipe.name %></h3>
                <p class="card-text"><%= recipe.description %></p>
            </div>
        </div>
      </div>
    <% end %>
  <% end %>
</div>
