<div class="row">
  <div class="col-sm-5 col-md-4 order-1 order-md-2">
    <i class="fa fa-calculator fa-lg orange icon-medium" aria-hidden="true"></i>
    <h1><%= t(:calculator_title) %></h1>
    <%= 
      render 'components/calculator',
      suggested_quantity: @suggested_quantity,
      suggested_portion: @suggested_portion,
      suggested_potency: @suggested_potency
    %>
    <div id="ad-medium-top">
      <%= render 'ads/medium' %>
    </div>
    <%= render 'dosage_widget', title: t(:dosage_title) %>
    <% if I18n.locale == :en %>
      <%= render 'suggest_recipe_button' %>
    <% end %>
  </div>

  <div class="col-sm-7 col-md-8 order-2 order-md-1">
    <%= render 'ads/donate' %>
    <div id="ad-leaderboard-top">
      <%= render 'ads/leaderboard' %>
    </div>
    <%= render 'recipes', recipes: @recipes %>
    <div class="pagination">
      <%= will_paginate @recipes, renderer: WillPaginate::ActionView::BootstrapLinkRenderer %>
    </div>
    <div id="ad-leaderboard-bottom">
      <%= render 'ads/leaderboard' %>
    </div>
    <div id="ad-medium-bottom">
      <%= render 'ads/medium' %>
    </div>
  </div>
</div>