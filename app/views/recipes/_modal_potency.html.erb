<!-- Modal -->
<div class="modal" id="myModal" tabindex="-1" role="dialog" aria-labelledby="exampleModalLabel" aria-hidden="true">
  <div class="modal-dialog" role="document">
    <div class="modal-content">
      <div class="modal-header">
        <strong><%= t :step1_potency_modal_title %></strong>
        <a class="close" data-dismiss="modal" aria-label="Close">
          <span aria-hidden="true">&times;</span>
        </a>
      </div>
      <div class="modal-body">
        <table class="table table-striped">
          <thead>
            <tr>
              <th><%= t :step1_potency_modal_column_one %></th>
              <th><%= t :step1_potency_modal_column_two %></th>
            </tr>
          </thead>
          <tbody>
            <tr>
              <td><%= t :step1_potency_modal_low_quality %></td>
              <td><%= t :step1_potency_modal_low_quantity %></td>
            </tr>
            <tr>
              <td><%= t :step1_potency_modal_medium_quality %></td>
              <td><%= t :step1_potency_modal_medium_quantity %></td>
            </tr>
            <tr>
              <td><%= t :step1_potency_modal_high_quality %></td>
              <td><%= t :step1_potency_modal_high_quantity %></td>
            </tr>
            <tr>
              <td><%= t :step1_potency_modal_concentrates %></td>
              <td><%= t :step1_potency_modal_concentrates_quantity %></td>
            </tr>
          </tbody>
        </table>
      </div>
      <div class="modal-footer">
        <a class="btn btn-secondary" data-dismiss="modal"><%= t :modal_close %></a>
      </div>
    </div>
  </div>
</div>
