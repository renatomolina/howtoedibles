<div class="col-sm-12">
  <div class="col-sm-12">
    <h4 class="text-left">
      <i class="fa fa-cutlery fa-lg og" aria-hidden="true"></i> <%= t :step3_title %>-
      <%= @recipe.name.capitalize.upcase %>
    </h4>
    <%= @recipe.ingredients.html_safe %>
  </div>
  <div class="col-sm-12 text-justify">
    <h4><i class="fa fa-list-ol fa-lg og" aria-hidden="true"></i>  <%= t :step3_step_by_step %></h4>
    <%= @recipe.instructions.html_safe %>
  </div>
  <div class="col-sm-12 video-container">
    <a href="#" class="thumbnail">
      <iframe width="100%" height="300px" src="<%= @recipe.video %>" frameborder="0" allowfullscreen></iframe>
    </a>
  </div>
  <br/>
</div>
