<%# Locals: recipes %>
<h2>
  <%= t :popular_recipes %>
  <i class="fa fa-caret-up fa-lg green" aria-hidden="true"></i>
</h2>
<% recipes.each_slice(3) do |recipes| %>
  <div class="d-none d-md-block">
    <div class="row">
      <% recipes.each do |recipe| %>
        <div class="col-sm-4">
          <%= link_to category_recipe_path(recipe.category.slug, recipe.slug) do %>
            <div class="card">
                <%= image_tag(recipe.photo.url,  class: 'card-img-top', alt: recipe.name) %>
                <div class="card-block">
                  <p class="card-title"><%= recipe.name %></p>
                  <p class="card-text"><%= recipe.description %></p>
                </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% recipes.each_slice(2) do |recipes| %>
  <div class="d-none d-sm-block d-md-none">
    <div class="row">
      <% recipes.each do |recipe| %>
        <div class="col-sm-6">
          <%= link_to category_recipe_path(recipe.category.slug, recipe.slug) do %>
            <div class="card">
                <%= image_tag(recipe.photo.url,  class: 'card-img-top', alt: recipe.name) %>
                <div class="card-block">
                  <p class="card-title"><%= recipe.name %></p>
                  <p class="card-text"><%= recipe.description %></p>
                </div>
            </div>
          <% end %>
        </div>
      <% end %>
    </div>
  </div>
<% end %>

<% recipes.each_slice(2) do |recipes| %>
  <div class="d-block d-sm-none">
    <% recipes.each do |recipe| %>
      <%= link_to category_recipe_path(recipe.category.slug, recipe.slug) do %>
        <div class="card">
          <div class="row no-gutters">
            <div class="col-auto">
              <%= image_tag(recipe.photo.url,  class: 'img-fluid card-img-left', alt: recipe.name) %>
            </div>
            <div class="col card-center">
              <div class="card-block">
                <h4 class="card-title"><%= recipe.name %></h4>
                <p class="card-text"><%= recipe.description %></p>
                <p class="card-text"><small class="text-muted"><%= recipe.category.name %></small></p>
              </div>
            </div>
          </div>
        </div>
      <% end %>
    <% end %>
  </div>
<% end %>