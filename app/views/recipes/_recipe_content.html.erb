<%# Locals: recipe %>
<h1>
  <i class="fa fa-cutlery fa-lg orange" aria-hidden="true"></i>  <%= t :step3_title %>
  <%= recipe.name.capitalize.camelcase %>
</h1>

<p class="ingredients-title"><strong><%= t :step3_ingredients_title %></strong></p>
<%= recipe.ingredients.html_safe %>

<br />

<h2>
  <i class="fa fa-list-ol fa-lg orange" aria-hidden="true"></i>  <%= t :step3_step_by_step %>
</h2>
<%= recipe.instructions.html_safe %>

<p><%= render 'commons/facebook_share_widget' %></p>

<% if recipe.video? %>
  <div class="video-container">
    <a href="#" class="thumbnail">
      <iframe width="100%" height="300px" src="<%= recipe.video %>" frameborder="0" allowfullscreen></iframe>
    </a>
  </div>
<% end %>

