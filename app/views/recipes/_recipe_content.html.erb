<%# Locals: recipe %>
<div class="recipe-title pt-4 pb-2">
  <h1>
    <%= t('calculator.step3_title') %> <%= recipe.name.capitalize.camelcase %>
  </h1>
</div>

<div class="recipe-content">
  <i class="fa fa-utensils fa-lg orange icon-medium" aria-hidden="true"></i>
  <h2><%= t('calculator.step3_ingredients_title') %></h2>
  <%= recipe.ingredients.html_safe %>

  <br />

  <i class="fa fa-list-ol fa-lg orange icon-medium" aria-hidden="true"></i>
  <h2><%= t('calculator.step3_step_by_step') %></h2>
  <%= recipe.instructions.html_safe %>
</div>

<p><%= render 'commons/facebook_share_widget' %></p>

<% if recipe.video? %>
  <div class="video-container">
    <a href="#" class="thumbnail">
      <iframe width="100%" height="300px" src="<%= recipe.video %>" frameborder="0" allowfullscreen></iframe>
    </a>
  </div>
<% end %>

