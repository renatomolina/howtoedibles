<div class="col-sm-12 container">
  <% if I18n.locale != :en %>
    <div class="col-sm-12 mtb">
      <%= render 'harm_reduction' %>
    </div>
  <% end %>
  <div class="row mtb">
    <div class="col-sm-6">
      <%= render 'calculator' %>
      <%= render 'dosage' %>
    </div>
    <div class="col-sm-6">
      <%= render 'recipe' %>
    </div>
  </div>
  <%= render 'layouts/warning' %>
</div>
<%= render 'i18n' %>
