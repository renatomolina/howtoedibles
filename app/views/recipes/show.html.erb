<%= render 'harm_reduction' %>
<div class="row">
  <div class="col-sm-5 order-1 order-md-2 padding-bottom">
    <%= render 'calculator_widget', title: t(:step1_title), suggested_weed: @recipe.suggested_weed, suggested_portion: @recipe.suggested_portion %>
