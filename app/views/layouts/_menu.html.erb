<nav class="navbar navbar-default">
  <div class="container">
    <div class="navbar-header">
      <button type="button" class="navbar-toggle" data-toggle="collapse" data-target="#navbar6">
      <span class="sr-only">Toggle navigation</span>
      <span class="icon-bar"></span>
      <span class="icon-bar"></span>
      <span class="icon-bar"></span>
      </button>
      <a class="image-logo" href="#"><%= image_tag(t(:logo), alt: 'How to Edibles', width: "47%", height:"55%")%></a>
    </div>
    <div id="navbar6" class="navbar-collapse collapse">
      <ul class="nav navbar-nav pull-right">
        <% @categories.each do |category| %>
          <li class="dropdown <%= tab_highlight?(params[:category_slug], category) %>">
            <a href="#" class="dropdown-toggle" data-toggle="dropdown" role="button" aria-expanded="false"><%= category.name %> <span class="caret"></span></a>
            <ul class="dropdown-menu" role="menu">
              <% category.recipes.each do |recipe| %>
                <li><%= link_to recipe.name, recipe_path(category.slug, recipe.slug) %></li>
              <% end %>
            </ul>
          </li>
        <% end %>
      </ul>
    </div>
  </div>
</nav>
