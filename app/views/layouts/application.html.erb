<!DOCTYPE html>
<html>
  <head>
    <title>How to edibles</title>
    <%= favicon_link_tag 'favicon.ico' %>
    <%= csrf_meta_tags %>

    <%= stylesheet_link_tag    'application', media: 'all', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag 'application', 'data-turbolinks-track': 'reload' %>
    <%= javascript_include_tag "https://cdnjs.cloudflare.com/ajax/libs/bootstrap-slider/9.7.0/bootstrap-slider.min.js" %>
    <%= javascript_include_tag "https://cdnjs.cloudflare.com/ajax/libs/pluralize/3.1.0/pluralize.min.js" %>
    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap.min.css" integrity="sha384-BVYiiSIFeK1dGmJRAkycuHAHRg32OmUcww7on3RYdg4Va+PmSTsz/K68vbdEjh4u" crossorigin="anonymous">

    <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/3.3.7/css/bootstrap-theme.min.css" integrity="sha384-rHyoN1iRsVXV4nD0JutlnGaslCJuC7uwjduW9SVrLvRYooPp2bWYgmgJQIXwl/Sp" crossorigin="anonymous">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/bootstrap-slider/9.7.0/css/bootstrap-slider.min.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/3.5.2/animate.min.css">
    <%= csrf_meta_tags %>

    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta charset='utf-8' />
    <meta name='description', content="Dose your edibles" />

    <meta property='og:site_name', content='How to Edibles' />
    <meta property='og:title', content='Dose your edibles' />
    <meta property='og:description', content="Dose your edibles" />

    <%= yield(:head) %>
  </head>

  <body>
    <header>
      <%= render 'layouts/menu' %>
    </header>
    <div class='main'>
      <div class='container'>
        <div class="alert alert-success" role="alert">This is a website projected to help your edibles experiences awesome. Start low, go slow.</div>
        <%= yield %>
      </div>
    </div>
    <%= render 'analytics' %>
  </body>
</html>
